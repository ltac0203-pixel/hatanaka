APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
# LOG_STACK: 本番では daily 推奨（ローテーション）。開発時のみ single でもよい。
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# LOG_LEVEL: 本番は warning 以上を推奨（debug はセンシティブ情報がログに残るリスクあり）。
# 開発時のみ debug を使用すること。
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=1440
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_FROM_ADDRESS_NO_REPLY=no-reply@example.com
MAIL_FROM_NAME_NO_REPLY="${APP_NAME}"
MAIL_FROM_ADDRESS_CONTACT=info@example.com
MAIL_FROM_NAME_CONTACT="${APP_NAME} Support"
MAIL_ADMIN_ADDRESS=no-reply@example.com

VITE_APP_NAME="${APP_NAME}"

# Fincode
FINCODE_API_KEY=
FINCODE_PUBLIC_KEY=
FINCODE_BASE_URL=https://api.test.fincode.jp
FINCODE_TENANT_SHOP_ID=
# Fincode SDK の SRI ハッシュ（任意・本番運用推奨）。
# 設定するとブラウザが SDK 改ざんを検知してロードを拒否できる。
# 生成: curl -sS https://js.fincode.jp/v1/fincode.js | openssl dgst -sha384 -binary | openssl base64 -A
# 注意: Fincode が SDK を更新するとハッシュが変わり、設定済み値ではカード登録が機能しなくなる。
# 詳細は docs/getting-started/fincode-setup.ja.md を参照。
FINCODE_SDK_SRI_HASH=

# Security headers
SECURITY_CSP_REPORT_ENABLED=true
SECURITY_CSP_REPORT_URI=/api/security/csp-reports
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_INCLUDE_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true

# 信頼するリバースプロキシ。本番でロードバランサ/CDN（CloudFront、ALB、Nginx等）配下に
# 配置する場合に必須。"*" は全プロキシ信頼（同一VPC内などプロキシ経路が制御されている前提）。
# 個別IP/CIDRをカンマ区切りで指定可能。未設定だと HSTS や secure cookie が発火しないことがある。
TRUSTED_PROXIES=*
